{
  "display_information": {
    "name": "Data Wizard",
    "description": "Upload CSVs and query your database in plain English",
    "background_color": "#1f2d3d"
  },
  "features": {
    "bot_user": {
      "display_name": "Data Wizard",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "files:read",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "files:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "file_shared",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}